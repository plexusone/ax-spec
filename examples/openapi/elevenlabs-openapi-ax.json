  /v1/history:
    get:
      description: Returns a list of your generated audio.
      operationId: get_speech_history
      parameters:
        - description: How many history items to return at maximum. Can not exceed 1000, defaults to 100.
          in: query
          name: page_size
          required: false
          schema:
            default: 100
            description: How many history items to return at maximum. Can not exceed 1000, defaults to 100.
            title: Page Size
            type: integer
        - description: After which ID to start fetching, use this parameter to paginate across a large collection of history items. In case this parameter is not provided history items will be fetched starting from the most recently created one ordered descending by their creation date.
          in: query
          name: start_after_history_item_id
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: After which ID to start fetching, use this parameter to paginate across a large collection of history items. In case this parameter is not provided history items will be fetched starting from the most recently created one ordered descending by their creation date.
            title: Start After History Item Id
        - description: Voice ID to be filtered for, you can use GET https://api.elevenlabs.io/v1/voices to receive a list of voices and their IDs.
          in: query
          name: voice_id
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Voice ID to be filtered for, you can use GET https://api.elevenlabs.io/v1/voices to receive a list of voices and their IDs.
            title: Voice Id
        - description: Model ID to filter history items by.
          in: query
          name: model_id
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Model ID to filter history items by.
            examples:
              - eleven_turbo_v2
              - eleven_multilingual_v2
            title: Model Id
        - description: Unix timestamp to filter history items before this date (exclusive).
          in: query
          name: date_before_unix
          required: false
          schema:
            anyOf:
              - type: integer
              - type: "null"
            description: Unix timestamp to filter history items before this date (exclusive).
            examples:
              - 1640995200
            title: Date Before Unix
        - description: Unix timestamp to filter history items after this date (inclusive).
          in: query
          name: date_after_unix
          required: false
          schema:
            anyOf:
              - type: integer
              - type: "null"
            description: Unix timestamp to filter history items after this date (inclusive).
            examples:
              - 1640995200
            title: Date After Unix
        - description: Sort direction for the results.
          in: query
          name: sort_direction
          required: false
          schema:
            anyOf:
              - enum:
                  - asc
                  - desc
                type: string
              - type: "null"
            default: desc
            description: Sort direction for the results.
            examples:
              - desc
              - asc
            title: Sort Direction
        - description: search term used for filtering
          in: query
          name: search
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: search term used for filtering
            examples:
              - In the land far far away
            title: Search
        - description: Source of the generated history item
          in: query
          name: source
          required: false
          schema:
            anyOf:
              - enum:
                  - TTS
                  - STS
                type: string
              - type: "null"
            description: Source of the generated history item
            examples:
              - TTS
            title: Source
        - description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
          in: header
          name: xi-api-key
          required: false
          schema:
            anyOf:
              - type: string
