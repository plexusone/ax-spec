      description: Trigger for Zendesk-initiated conversations.
      properties:
        ticket_id:
          title: Ticket Id
          type: integer
        trigger_type:
          const: zendesk
          default: zendesk
          title: Trigger Type
          type: string
      required:
        - ticket_id
      title: ZendeskConversationInitiationTrigger
      type: object
info:
  description: This is the documentation for the ElevenLabs API. You can use this API to use our service programmatically, this is done by using your API key. You can find your API key in the dashboard at https://elevenlabs.io/app/settings/api-keys.
  title: ElevenLabs API Documentation
  version: "1.0"
openapi: 3.1.0
paths:
  /docs:
    get:
      operationId: redirect_to_mintlify
      responses:
        "200":
          content:
            application/json:
              schema: {}
          description: Successful Response
      summary: Redirect To Mintlify
      x-ax-capabilities:
        - redirect_to_mintlify
      x-ax-retryable: true
      x-ax-sandboxable: true
  /v1/audio-isolation:
    post:
      description: Removes background noise from audio
      operationId: audio_isolation
      parameters:
        - description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
          in: header
          name: xi-api-key
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
            title: Xi-Api-Key
      requestBody:
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Body_Audio_Isolation_v1_audio_isolation_post'
        required: true
      responses:
        "200":
          content:
            audio/mpeg: {}
          description: Successful Response
        "422":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/HTTPValidationError'
          description: Validation Error
      summary: Audio Isolation
      tags:
        - audio-isolation
      x-ax-capabilities:
        - audio_isolation
      x-ax-retryable: false
      x-ax-sandboxable: true
      x-fern-sdk-group-name: audio_isolation
      x-fern-sdk-method-name: convert
  /v1/audio-isolation/stream:
    post:
      description: Removes background noise from audio and streams the result
      operationId: audio_isolation_stream
      parameters:
        - description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
          in: header
          name: xi-api-key
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
            title: Xi-Api-Key
      requestBody:
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Body_Audio_Isolation_Stream_v1_audio_isolation_stream_post'
        required: true
      responses:
        "200":
          content:
            audio/mpeg: {}
          description: Successful Response
        "422":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/HTTPValidationError'
          description: Validation Error
      summary: Audio Isolation Stream
      tags:
        - audio-isolation
      x-ax-capabilities:
        - audio_isolation_stream
      x-ax-retryable: false
      x-ax-sandboxable: true
      x-fern-sdk-group-name: audio_isolation
      x-fern-sdk-method-name: stream
      x-fern-streaming: true
  /v1/audio-native:
    post:
      description: Creates Audio Native enabled project, optionally starts conversion and returns project ID and embeddable HTML snippet.
      operationId: create_audio_native_project
      parameters:
        - description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
          in: header
          name: xi-api-key
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
            title: Xi-Api-Key
      requestBody:
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Body_Creates_Audio_Native_enabled_project__v1_audio_native_post'
        required: true
      responses:
        "200":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AudioNativeCreateProjectResponseModel'
          description: Successful Response
        "422":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/HTTPValidationError'
          description: Validation Error
      summary: Creates Audio Native Enabled Project.
      tags:
        - audio-native
      x-ax-capabilities:
        - create_audio_native_project
        - write
      x-ax-retryable: false
      x-ax-sandboxable: true
      x-fern-sdk-group-name: audio_native
      x-fern-sdk-method-name: create
  /v1/audio-native/{project_id}/content:
    post:
      description: Updates content for the specific AudioNative Project.
      operationId: audio_native_project_update_content_endpoint
      parameters:
        - description: The ID of the Studio project.
          in: path
          name: project_id
          required: true
          schema:
            description: The ID of the Studio project.
            examples:
              - 21m00Tcm4TlvDq8ikWAM
            title: Project Id
            type: string
        - description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
          in: header
          name: xi-api-key
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
            title: Xi-Api-Key
      requestBody:
        content:
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/Body_Update_audio_native_Project_content_v1_audio_native__project_id__content_post'
      responses:
        "200":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/AudioNativeEditContentResponseModel'
          description: Successful Response
        "400":
          x-ax-error-code: INVALID_UID
          x-ax-error-suggestion: 'An invalid ID has been received: ''invalid-id-12345''. Make sure to provide a correct one.'
        "422":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/HTTPValidationError'
          description: Validation Error
      summary: Update Audio-Native Project Content
      tags:
        - audio-native
      x-ax-capabilities:
        - audio_native_project_update_content_endpoint
      x-ax-retryable: false
      x-ax-sandboxable: true
      x-fern-sdk-group-name: audio_native
      x-fern-sdk-method-name: update
  /v1/audio-native/{project_id}/settings:
    get:
      description: Get player settings for the specific project.
      operationId: get_audio_native_project_settings_endpoint
      parameters:
        - description: The ID of the Studio project.
          in: path
          name: project_id
          required: true
          schema:
            description: The ID of the Studio project.
            examples:
              - 21m00Tcm4TlvDq8ikWAM
            title: Project Id
            type: string
        - description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
          in: header
          name: xi-api-key
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
            title: Xi-Api-Key
      responses:
        "200":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GetAudioNativeProjectSettingsResponseModel'
          description: Successful Response
        "400":
          x-ax-error-code: INVALID_UID
          x-ax-error-suggestion: 'An invalid ID has been received: ''invalid-id-12345''. Make sure to provide a correct one.'
        "422":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/HTTPValidationError'
          description: Validation Error
      summary: Get Audio Native Project Settings
      tags:
        - audio-native
      x-ax-capabilities:
        - get_audio_native_project_settings_endpoint
        - read
      x-ax-retryable: true
      x-ax-sandboxable: true
      x-fern-sdk-group-name: audio_native
      x-fern-sdk-method-name: get_settings
  /v1/convai/agent-testing:
    get:
      description: Lists all agent response tests with pagination support and optional search filtering.
      operationId: list_chat_response_tests_route
      parameters:
        - description: Used for fetching next page. Cursor is returned in the response.
          in: query
          name: cursor
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Used for fetching next page. Cursor is returned in the response.
            title: Cursor
        - description: How many Tests to return at maximum. Can not exceed 100, defaults to 30.
          in: query
          name: page_size
          required: false
          schema:
            default: 30
            description: How many Tests to return at maximum. Can not exceed 100, defaults to 30.
            maximum: 100
            minimum: 1
            title: Page Size
            type: integer
        - description: Search query to filter tests by name.
          in: query
          name: search
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Search query to filter tests by name.
            title: Search
        - description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
          in: header
          name: xi-api-key
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
            title: Xi-Api-Key
      responses:
        "200":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/GetTestsPageResponseModel'
          description: Successful Response
        "401":
          x-ax-error-code: NEEDS_AUTHORIZATION
          x-ax-error-suggestion: Neither authorization header nor xi-api-key received, please provide one.
        "422":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/HTTPValidationError'
          description: Validation Error
      summary: List Agent Response Tests
      x-ax-capabilities:
        - list_chat_response_tests_route
        - read
      x-ax-retryable: true
      x-ax-sandboxable: true
      x-fern-sdk-group-name:
        - conversational_ai
        - tests
      x-fern-sdk-method-name: list
  /v1/convai/agent-testing/{test_id}:
    delete:
      description: Deletes an agent response test by ID.
      operationId: delete_chat_response_test_route
      parameters:
        - description: The id of a chat response test. This is returned on test creation.
          in: path
          name: test_id
