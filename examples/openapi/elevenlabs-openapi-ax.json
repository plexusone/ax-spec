        prompt:
          anyOf:
            - maxLength: 4100
              type: string
            - type: "null"
          description: A simple text prompt to generate a song from. Cannot be used in conjunction with `composition_plan`.
          title: Prompt
        seed:
          anyOf:
            - maximum: 2.147483647e+09
