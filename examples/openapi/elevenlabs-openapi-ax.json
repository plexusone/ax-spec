  /v1/text-to-dialogue:
    post:
      description: Converts a list of text and voice ID pairs into speech (dialogue) and returns audio.
      operationId: text_to_dialogue
      parameters:
        - description: Output format of the generated audio. Formatted as codec_sample_rate_bitrate. So an mp3 with 22.05kHz sample rate at 32kbs is represented as mp3_22050_32. MP3 with 192kbps bitrate requires you to be subscribed to Creator tier or above. PCM with 44.1kHz sample rate requires you to be subscribed to Pro tier or above. Note that the μ-law format (sometimes written mu-law, often approximated as u-law) is commonly used for Twilio audio inputs.
          in: query
          name: output_format
          required: false
          schema:
            default: mp3_44100_128
            description: Output format of the generated audio. Formatted as codec_sample_rate_bitrate. So an mp3 with 22.05kHz sample rate at 32kbs is represented as mp3_22050_32. MP3 with 192kbps bitrate requires you to be subscribed to Creator tier or above. PCM with 44.1kHz sample rate requires you to be subscribed to Pro tier or above. Note that the μ-law format (sometimes written mu-law, often approximated as u-law) is commonly used for Twilio audio inputs.
            enum:
              - mp3_22050_32
              - mp3_24000_48
              - mp3_44100_32
              - mp3_44100_64
              - mp3_44100_96
              - mp3_44100_128
              - mp3_44100_192
              - pcm_8000
              - pcm_16000
              - pcm_22050
              - pcm_24000
              - pcm_32000
              - pcm_44100
              - pcm_48000
              - ulaw_8000
              - alaw_8000
              - opus_48000_32
              - opus_48000_64
              - opus_48000_96
              - opus_48000_128
              - opus_48000_192
            title: Output format of the generated audio.
            type: string
        - description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
          in: header
          name: xi-api-key
          required: false
          schema:
            anyOf:
              - type: string
              - type: "null"
            description: Your API key. This is required by most endpoints to access our API programmatically. You can view your xi-api-key using the 'Profile' tab on the website.
            title: Xi-Api-Key
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Body_Text_to_dialogue__multi_voice__v1_text_to_dialogue_post'
        required: true
      responses:
        "200":
          content:
            audio/mpeg:
              schema:
                format: binary
                type: string
          description: The generated audio file
        "422":
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/HTTPValidationError'
          description: Validation Error
      summary: Text To Dialogue (Multi-Voice)
      tags:
        - text-to-dialogue
      x-ax-capabilities:
        - text_to_dialogue
      x-ax-required-fields:
        - inputs
      x-ax-retryable: false
      x-ax-sandboxable: true
      x-fern-sdk-group-name: text_to_dialogue
      x-fern-sdk-method-name: convert
  /v1/text-to-dialogue/stream:
    post:
      description: Converts a list of text and voice ID pairs into speech (dialogue) and returns an audio stream.
      operationId: text_to_dialogue_stream
      parameters:
        - description: Output format of the generated audio. Formatted as codec_sample_rate_bitrate. So an mp3 with 22.05kHz sample rate at 32kbs is represented as mp3_22050_32. MP3 with 192kbps bitrate requires you to be subscribed to Creator tier or above. PCM with 44.1kHz sample rate requires you to be subscribed to Pro tier or above. Note that the μ-law format (sometimes written mu-law, often approximated as u-law) is commonly used for Twilio audio inputs.
