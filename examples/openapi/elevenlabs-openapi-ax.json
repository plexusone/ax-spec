      example:
        message: Hhmmmm...yeah give me a second...
        timeout_seconds: 2
      properties:
        message:
          default: Hhmmmm...yeah give me a second...
          description: Message to show when soft timeout is reached while waiting for LLM response
          maxLength: 200
          minLength: 1
