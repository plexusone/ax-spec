components:
  schemas:
    ASRConversationalConfig:
      example:
        keywords:
          - hello
          - world
        provider: elevenlabs
        quality: high
        user_input_audio_format: pcm_16000
      properties:
        keywords:
          description: Keywords to boost prediction probability for
          items:
            type: string
          title: Keywords
          type: array
        provider:
          $ref: '#/components/schemas/ASRProvider'
          default: elevenlabs
          description: The provider of the transcription service
        quality:
          $ref: '#/components/schemas/ASRQuality'
          default: high
          description: The quality of the transcription
        user_input_audio_format:
          $ref: '#/components/schemas/ASRInputFormat'
          default: pcm_16000
          description: The format of the audio to be transcribed
      title: ASRConversationalConfig
      type: object
    ASRConversationalConfigWorkflowOverride:
      example:
        keywords:
          - hello
          - world
        provider: elevenlabs
        quality: high
        user_input_audio_format: pcm_16000
      properties:
        keywords:
          anyOf:
            - items:
                type: string
              type: array
            - type: "null"
          description: Keywords to boost prediction probability for
          title: Keywords
        provider:
          anyOf:
            - $ref: '#/components/schemas/ASRProvider'
            - type: "null"
          description: The provider of the transcription service
        quality:
          anyOf:
            - $ref: '#/components/schemas/ASRQuality'
            - type: "null"
          description: The quality of the transcription
        user_input_audio_format:
          anyOf:
            - $ref: '#/components/schemas/ASRInputFormat'
            - type: "null"
          description: The format of the audio to be transcribed
      title: ASRConversationalConfigWorkflowOverride
      type: object
    ASRInputFormat:
      enum:
        - pcm_8000
        - pcm_16000
        - pcm_22050
        - pcm_24000
        - pcm_44100
        - pcm_48000
        - ulaw_8000
      title: ASRInputFormat
      type: string
    ASRProvider:
      enum:
        - elevenlabs
        - scribe_realtime
      title: ASRProvider
      type: string
    ASRQuality:
      enum:
        - high
      title: ASRQuality
      type: string
